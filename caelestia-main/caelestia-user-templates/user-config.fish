#
# This file is sourced at the END of fish/config.fish — your additions always
# take precedence. Add custom aliases, functions, and env vars here.
# =============================================================================

# ─── Custom aliases ──────────────────────────────────────────────────────────
# alias vim 'nvim'
# alias cat 'bat'
# alias find 'fd'

# ─── PATH additions ──────────────────────────────────────────────────────────
# fish_add_path ~/.cargo/bin
# fish_add_path ~/.local/bin

# ─── Environment variables ───────────────────────────────────────────────────
# set -x EDITOR nvim
# set -x BROWSER zen-browser

# ─── Greeting override ───────────────────────────────────────────────────────
